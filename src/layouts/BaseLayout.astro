---
/**
 * BaseLayout.astro — esqueleto <html> compartido (§7, §9.3).
 * ─────────────────────────────────────────────────────────────────────────────────────
 * - Script anti-FOUC `is:inline` (fija `data-theme` y la clase `motion-ready` ANTES del primer
 *   paint y los re-aplica en `astro:after-swap` para View Transitions).
 * - `<ClientRouter/>`: View Transitions entre páginas (index ↔ 404) (§6.4 Fase 4).
 * - SEO técnico base: canonical, Open Graph, Twitter Card, color-scheme/theme-color por tema.
 * - Datos estructurados: cada string de `jsonLd` se emite como un <script type=ld+json>.
 * - Preload de la fuente del hero (LCP), skip-link y overlay de grano.
 * - Bootstrap de motion (`scripts/motion`): se importa en diferido solo bajo `no-preference`.
 */
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  /** Bloques JSON-LD ya serializados (p. ej. GasStation, FAQPage). */
  jsonLd?: string[];
}

const { title, description = SITE.description, jsonLd = [] } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.name}` : SITE.titleDefault;

// URLs absolutas para canonical / OG (requieren `site` en astro.config.mjs).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(SITE.ogImage, Astro.site).href;
---

<!doctype html>
<html lang="es-DO" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {
      /* theme-color del chrome del navegador: lo fija el script anti-FOUC para que SIGA al tema
        elegido (data-theme/localStorage), no al del sistema operativo. Va antes del script para
        que ya exista al primer apply(). */
    }
    <meta name="theme-color" content="#0e3b32" />

    {
      /* Anti-FOUC: lo primero, antes del CSS, para evitar el flash de tema al cargar/navegar.
        Fija además `motion-ready` ANTES del primer paint, de modo que el CSS pueda ocultar los
        scroll-reveals sin parpadeo (solo si hay JS y el usuario NO pidió reducir movimiento).
        Se re-ejecuta en `astro:after-swap` porque las View Transitions reinician los atributos
        y clases de <html> a los de la página entrante. */
    }
    <script is:inline>
      (function () {
        const root = document.documentElement;
        const apply = function () {
          let theme = 'light';
          try {
            const s = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            theme =
              s === 'dark' ? 'dark' : s === 'light' ? 'light' : prefersDark ? 'dark' : 'light';
          } catch {
            /* localStorage no disponible: se queda en el tema por defecto (claro). */
          }
          root.dataset.theme = theme;
          /* theme-color sigue al tema: verde de marca en claro (#0e3b32, como el header),
             fondo oscuro en dark (#0b1512 = --bg dark). Mismo valor que usa el ThemeToggle. */
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0b1512' : '#0e3b32');
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          root.classList.toggle('motion-ready', !reduce);
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>

    <ClientRouter />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="color-scheme" content="light dark" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_DO" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE.ogImageAlt} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={SITE.ogImageAlt} />

    {/* Preload de la fuente display (LCP del hero). 🔔 Surte efecto al subir el .woff2. */}
    <link
      rel="preload"
      href="/fonts/ClashDisplay-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* Datos estructurados (§9.3). set:html con string ya serializado por lib/seo.ts. */}
    {jsonLd.map((block) => <script type="application/ld+json" is:inline set:html={block} />)}

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar al contenido</a>
    <slot />
    <div class="grain-overlay" aria-hidden="true"></div>

    {
      /* Motion (§6.4): Lenis + GSAP/ScrollTrigger/SplitText. Se IMPORTA en diferido solo si el
        usuario permite movimiento → bajo prefers-reduced-motion no se descarga ni un byte de
        GSAP/Lenis (a11y + perf). El módulo se autogestiona en los eventos del ClientRouter. */
    }
    <script>
      if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        import('../scripts/motion');
      }
    </script>
  </body>
</html>
