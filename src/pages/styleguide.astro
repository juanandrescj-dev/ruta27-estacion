---
/**
 * /styleguide — PÁGINA TEMPORAL (Fase 1). Vitrina del sistema de diseño para QA visual en
 * ambos temas. Se ELIMINA en la Fase 2. No se enlaza desde la navegación pública.
 */
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import ThemeToggle from '../components/interactive/ThemeToggle.tsx';
import Surtidor from '../components/ui/icons/Surtidor.astro';
import Lavado from '../components/ui/icons/Lavado.astro';
import GLP from '../components/ui/icons/GLP.astro';
import Aire from '../components/ui/icons/Aire.astro';
import { Fuel, MapPin, Clock, Phone, ArrowRight, Check, Store, Coffee } from '@lucide/astro';
import { formatRD, formatFechaLarga } from '../lib/utils/format';
import { estaAbiertoAhora, type DiaHorario } from '../lib/utils/horarios';

const combustibles = await getCollection('combustibles');
const vigenciaRef = combustibles[0]?.data.vigencia;
const estacion = (await getEntry('estacion', 'ruta27'))?.data;
const horarios: DiaHorario[] = (await getCollection('horarios')).map((e) => ({
  id: e.id,
  ...e.data,
}));
const estado = estaAbiertoAhora(horarios);

const semanticos = [
  'bg',
  'surface',
  'surface-sunken',
  'surface-raised',
  'brand',
  'brand-strong',
  'accent',
  'accent-text',
  'signal',
  'ink',
  'ink-muted',
  'border',
] as const;

const escalaTipografica = [
  { clase: 'text-display font-display', etiqueta: 'display · clamp 40→72', muestra: 'Ruta 27' },
  { clase: 'text-h1 font-display', etiqueta: 'h1 · 49', muestra: 'Energía para tu ruta' },
  { clase: 'text-h2 font-display', etiqueta: 'h2 · 39', muestra: 'Combustible de confianza' },
  { clase: 'text-h3 font-display', etiqueta: 'h3 · 31', muestra: 'Abierto 24/7' },
  { clase: 'text-lead font-sans', etiqueta: 'lead · 20', muestra: 'Llena el tanque y sigue.' },
  {
    clase: 'text-body font-sans',
    etiqueta: 'body · 16 / 1.65',
    muestra: 'Despacho a galón exacto, precio justo en RD$.',
  },
  { clase: 'text-small font-sans', etiqueta: 'small · 14', muestra: 'Precios ilustrativos.' },
];

const swatchVar: Record<string, string> = {
  brand: 'var(--brand)',
  'brand-strong': 'var(--brand-strong)',
  accent: 'var(--accent)',
  'accent-text': 'var(--accent-text)',
  signal: 'var(--signal)',
};
---

<BaseLayout title="Guía de estilo" description="Vitrina temporal del sistema de diseño de Ruta 27.">
  <header
    class="sticky top-0 z-50 border-b border-line bg-surface/85 backdrop-blur-md supports-[backdrop-filter]:bg-surface/70"
  >
    <Container size="wide" class="flex items-center justify-between gap-4 py-3">
      <div class="flex items-baseline gap-3">
        <span class="font-display text-h3 leading-none font-semibold text-brand">Ruta 27</span>
        <span class="text-small text-ink-muted">· Guía de estilo</span>
      </div>
      <div class="flex items-center gap-3">
        <Badge variant="accent" class="hidden sm:inline-flex">Temporal · Fase 1</Badge>
        <ThemeToggle client:idle />
      </div>
    </Container>
  </header>

  <main id="main">
    <Container size="wide" class="flex flex-col gap-20 py-14 sm:gap-24 sm:py-20">
      <!-- Intro -->
      <section class="max-w-2xl">
        <Eyebrow numero="00">Sistema de diseño</Eyebrow>
        <h1 class="mt-4 font-display text-h1 font-semibold text-balance">
          Tokens, tipografía y componentes base de <span class="text-brand">Ruta 27</span>.
        </h1>
        <p class="mt-4 text-lead text-ink-muted">
          Página de verificación visual. Todo sale de <code class="text-accent-text"
            >tokens.css</code
          >; el tema claro/oscuro cambia con el toggle de arriba. Esta página se borra en la Fase 2.
        </p>
      </section>

      <!-- 01 · Color -->
      <section>
        <Eyebrow numero="01">Color · tokens semánticos</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">Paleta (tema activo)</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
          {
            semanticos.map((tok) => (
              <div class="overflow-hidden rounded-lg border border-line bg-surface">
                <div class="h-16 w-full" style={`background-color: var(--${tok})`} />
                <div class="border-t border-line px-3 py-2">
                  <code class="text-small font-semibold text-ink">--{tok}</code>
                </div>
              </div>
            ))
          }
        </div>

        <h3 class="mt-10 mb-4 font-display text-h3 font-semibold">Claro vs. oscuro, lado a lado</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            (['light', 'dark'] as const).map((t) => (
              <div data-theme={t} class="rounded-xl border border-line bg-bg p-5 text-ink shadow-2">
                <p class="mb-3 text-eyebrow font-semibold tracking-[0.12em] text-accent-text uppercase">
                  {t === 'light' ? 'Claro' : 'Oscuro'}
                </p>
                <div class="flex flex-wrap gap-2">
                  {(['brand', 'accent', 'signal', 'surface', 'ink'] as const).map((tok) => (
                    <span
                      class="size-9 rounded-md border border-line"
                      style={`background-color: var(--${tok})`}
                      title={`--${tok}`}
                    />
                  ))}
                </div>
                <p class="mt-3 text-body">
                  Texto de muestra · <span class="text-ink-muted">secundario</span> ·{' '}
                  <span class="font-semibold text-accent-text">acento AA</span>
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 02 · Tipografía -->
      <section>
        <Eyebrow numero="02">Tipografía · Clash Display + Switzer</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">Escala modular fluida</h2>
        <div class="flex flex-col gap-5">
          {
            escalaTipografica.map((t) => (
              <div class="flex flex-col gap-1 border-b border-line pb-5 last:border-0">
                <span class="text-eyebrow font-semibold tracking-[0.12em] text-ink-muted uppercase">
                  {t.etiqueta}
                </span>
                <span class={t.clase}>{t.muestra}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 03 · Botones -->
      <section>
        <Eyebrow numero="03">Botones</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">Variantes, tamaños y estados</h2>
        <div class="flex flex-col gap-8">
          <div class="flex flex-wrap items-center gap-4">
            <Button variant="primario">Cómo llegar</Button>
            <Button variant="secundario">Ver precios</Button>
            <Button variant="ghost">Más información</Button>
          </div>
          <div class="flex flex-wrap items-center gap-4">
            <Button variant="primario" size="sm">Pequeño</Button>
            <Button variant="primario" size="md">Mediano</Button>
            <Button variant="primario" size="lg">Grande</Button>
            <Button variant="primario" href="#03">Como enlace <ArrowRight size={18} /></Button>
          </div>
          <div class="flex flex-wrap items-center gap-4">
            <Button variant="primario" disabled>Deshabilitado</Button>
            <Button variant="secundario" disabled>Deshabilitado</Button>
            <span class="text-small text-ink-muted"
              >Pasa el cursor / usa Tab para ver hover y focus.</span
            >
          </div>
        </div>
      </section>

      <!-- 04 · Cards -->
      <section>
        <Eyebrow numero="04">Tarjetas · elevación</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">Superficie sólida + borde 1px</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          <Card>
            <h3 class="font-display text-h3 font-semibold">Default</h3>
            <p class="mt-2 text-body text-ink-muted">Superficie base con sombra nivel 1.</p>
          </Card>
          <Card variant="raised">
            <h3 class="font-display text-h3 font-semibold">Raised</h3>
            <p class="mt-2 text-body text-ink-muted">
              Elevada: en oscuro se aclara, no proyecta sombra fuerte.
            </p>
          </Card>
          <Card variant="sunken" interactive>
            <h3 class="font-display text-h3 font-semibold">Sunken + interactiva</h3>
            <p class="mt-2 text-body text-ink-muted">Pasa el cursor: sube y realza el borde.</p>
          </Card>
        </div>
      </section>

      <!-- 05 · Badges -->
      <section>
        <Eyebrow numero="05">Badges</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">Pill solo aquí</h2>
        <div class="flex flex-wrap items-center gap-3">
          <Badge variant="brand" dot>{estado.etiqueta}</Badge>
          <Badge variant="accent">Actualizado</Badge>
          <Badge variant="neutral">RNC {estacion?.rnc}</Badge>
          <Badge variant="signal">Precio sujeto a cambio</Badge>
        </div>
      </section>

      <!-- 06 · Iconografía -->
      <section>
        <Eyebrow numero="06">Iconografía · línea coherente</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">
          Dominio (propios) + Lucide (UI)
        </h2>
        <div class="grid grid-cols-3 gap-4 sm:grid-cols-4 lg:grid-cols-6">
          {
            [
              { c: Surtidor, n: 'Surtidor' },
              { c: Lavado, n: 'Lavado' },
              { c: GLP, n: 'GLP' },
              { c: Aire, n: 'Aire' },
            ].map((i) => (
              <div class="flex flex-col items-center gap-2 rounded-lg border border-line bg-surface p-4 text-brand">
                <i.c size={28} />
                <span class="text-small text-ink-muted">{i.n}</span>
              </div>
            ))
          }
          {
            [
              { C: Fuel, n: 'fuel' },
              { C: Store, n: 'store' },
              { C: Coffee, n: 'coffee' },
              { C: MapPin, n: 'map-pin' },
              { C: Clock, n: 'clock' },
              { C: Phone, n: 'phone' },
              { C: Check, n: 'check' },
              { C: ArrowRight, n: 'arrow-right' },
            ].map((i) => (
              <div class="flex flex-col items-center gap-2 rounded-lg border border-line bg-surface p-4 text-ink">
                <i.C size={28} stroke-width={1.75} />
                <span class="text-small text-ink-muted">{i.n}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 07 · Elevación y radios -->
      <section>
        <Eyebrow numero="07">Elevación y radios</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">
          Sombras de marca · radios variados
        </h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {
            (['shadow-1', 'shadow-2', 'shadow-3'] as const).map((s) => (
              <div class={`flex h-24 items-center justify-center rounded-lg bg-surface ${s}`}>
                <code class="text-small text-ink-muted">{s}</code>
              </div>
            ))
          }
        </div>
        <div class="mt-4 flex flex-wrap items-end gap-4">
          {
            [
              ['rounded-sm', '6px · botones'],
              ['rounded-md', '10px · inputs'],
              ['rounded-lg', '14px · cards'],
              ['rounded-xl', '20px · bento'],
              ['rounded-full', 'pill · badges'],
            ].map(([r, label]) => (
              <div class="flex flex-col items-center gap-2">
                <div class={`size-16 border border-line bg-surface-sunken ${r}`} />
                <code class="text-small text-ink-muted">{label}</code>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 08 · Datos -->
      <section>
        <Eyebrow numero="08">Datos · YAML + Zod + format.ts</Eyebrow>
        <h2 class="mt-3 mb-6 font-display text-h2 font-semibold">Combustibles y precios</h2>
        <div class="overflow-hidden rounded-lg border border-line">
          <table class="w-full border-collapse text-left">
            <thead class="bg-surface-sunken">
              <tr class="text-eyebrow tracking-[0.12em] text-ink-muted uppercase">
                <th scope="col" class="px-4 py-3 font-semibold">Combustible</th>
                <th scope="col" class="px-4 py-3 font-semibold">Precio / galón</th>
                <th scope="col" class="hidden px-4 py-3 font-semibold sm:table-cell">Vigencia</th>
              </tr>
            </thead>
            <tbody>
              {
                combustibles.map((c) => (
                  <tr class="border-t border-line bg-surface">
                    <td class="px-4 py-3">
                      <span class="inline-flex items-center gap-2.5">
                        <span
                          class="size-3 shrink-0 rounded-full"
                          style={`background-color: ${swatchVar[c.data.swatch]}`}
                          aria-hidden="true"
                        />
                        <span class="font-semibold text-ink">{c.data.nombre}</span>
                        {c.data.octanaje && (
                          <span class="text-small text-ink-muted">{c.data.octanaje} oct.</span>
                        )}
                      </span>
                    </td>
                    <td class="px-4 py-3 font-display font-semibold text-brand tabular-nums">
                      {formatRD(c.data.precioRD)}
                    </td>
                    <td class="hidden px-4 py-3 text-small text-ink-muted sm:table-cell">
                      {formatFechaLarga(c.data.vigencia)}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-small text-ink-muted">
          Precios oficiales ilustrativos{
            vigenciaRef ? ` · actualizados al ${formatFechaLarga(vigenciaRef)}` : ''
          }.
        </p>
      </section>

      <footer class="border-t border-line pt-8 text-small text-ink-muted">
        <p>
          Sitio demostrativo de portafolio. «Ruta 27» es una marca ficticia; datos, precios e
          imágenes son ilustrativos.
        </p>
      </footer>
    </Container>
  </main>
</BaseLayout>
