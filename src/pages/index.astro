---
/**
 * index.astro — home de Ruta 27 (single-page). Compone el Header, las secciones de contenido
 * (Hero → FAQ) y el Footer. Inyecta los datos estructurados (GasStation + FAQPage) construidos
 * a partir de los MISMOS YAML que pinta la UI, así el SEO no se desincroniza (§9.3).
 * Ubicación (#ubicacion, mapa) y Contacto (#contacto, formulario) llegan en la Fase 3.
 */
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
import { buildGasStationJsonLd, buildFaqJsonLd, type EstacionSEO } from '../lib/seo';
import type { DiaHorario } from '../lib/utils/horarios';

import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Combustibles from '../components/sections/Combustibles.astro';
import Servicios from '../components/sections/Servicios.astro';
import SobreLaEstacion from '../components/sections/SobreLaEstacion.astro';
import Diferenciadores from '../components/sections/Diferenciadores.astro';
import Ubicacion from '../components/sections/Ubicacion.astro';
import Horarios from '../components/sections/Horarios.astro';
import FAQ from '../components/sections/FAQ.astro';
import Contacto from '../components/sections/Contacto.astro';

const estacion = (await getEntry('estacion', 'ruta27'))?.data as EstacionSEO;
const horarios: DiaHorario[] = (await getCollection('horarios')).map((e) => ({
  id: e.id,
  ...e.data,
}));
// Mismo orden que el acordeón visible (FAQ.astro) → el FAQPage no se desincroniza.
const faq = (await getCollection('faq'))
  .sort((a, b) => a.data.orden - b.data.orden)
  .map((f) => f.data);

const jsonLd = [
  buildGasStationJsonLd({
    estacion,
    horarios,
    site: Astro.site,
    imagePath: SITE.ogImage,
  }),
  buildFaqJsonLd(faq),
];
---

<BaseLayout jsonLd={jsonLd}>
  <Header />
  <main id="main">
    <Hero />
    <Combustibles />
    <Servicios />
    <SobreLaEstacion />
    <Diferenciadores />
    <Ubicacion />
    <Horarios />
    <FAQ />
    <Contacto />
  </main>
  <Footer />
</BaseLayout>
