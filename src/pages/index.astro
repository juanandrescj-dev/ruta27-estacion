---
/**
 * index.astro — placeholder "próximamente" (la home real se construye en la Fase 2).
 * Ya usa el sistema de diseño de la Fase 1: tokens, fuentes, dark mode con toggle y skip-link.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Badge from '../components/ui/Badge.astro';
import ThemeToggle from '../components/interactive/ThemeToggle.tsx';
import { getEntry } from 'astro:content';

const estacion = (await getEntry('estacion', 'ruta27'))?.data;
const year = new Date().getFullYear();
---

<BaseLayout>
  <header class="absolute inset-x-0 top-0 z-50">
    <Container size="wide" class="flex items-center justify-between py-5">
      <span class="font-display text-h3 leading-none font-semibold text-brand">Ruta 27</span>
      <ThemeToggle client:idle />
    </Container>
  </header>

  <main id="main" class="flex min-h-[100dvh] flex-col justify-center py-28">
    <Container size="default" class="flex flex-col items-start">
      <Eyebrow numero="00">Próximamente</Eyebrow>
      <h1 class="mt-5 max-w-3xl font-display text-display font-semibold text-balance">
        {estacion?.eslogan ?? 'Energía para seguir tu ruta'}.
      </h1>
      <p class="mt-6 max-w-xl text-lead text-ink-muted">
        Estamos construyendo el nuevo sitio de <strong class="font-semibold text-ink"
          >Ruta 27</strong
        >, tu estación de servicio en la Autopista Duarte. Abierta 24/7, gasolina y gasoil de
        calidad, precio justo en&nbsp;RD$.
      </p>
      <div class="mt-8">
        <Badge variant="brand" dot>Sitio en construcción</Badge>
      </div>
    </Container>
  </main>

  <footer class="border-t border-line py-8">
    <Container size="default" class="flex flex-col gap-2 text-small text-ink-muted">
      <p>© {year} Ruta 27 — Estación de Servicio.</p>
      <p class="max-w-2xl">
        Sitio demostrativo de portafolio. «Ruta 27» es una marca ficticia; datos, precios e imágenes
        son ilustrativos.
      </p>
    </Container>
  </footer>
</BaseLayout>
