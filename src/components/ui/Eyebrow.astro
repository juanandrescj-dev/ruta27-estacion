---
/**
 * Eyebrow.astro — antetítulo con numeración editorial "01 / SERVICIOS" (anti-IA tell #14).
 * El número + una fina regla separan del rótulo; uppercase con tracking y color de acento (AA).
 */
import type { HTMLTag } from 'astro/types';
import { cn } from '../../lib/utils/cn';

interface Props {
  /** Numeración editorial, p. ej. "01", "00". Opcional. */
  numero?: string;
  as?: HTMLTag;
  class?: string;
}

const { numero, as: Tag = 'p', class: className }: Props = Astro.props;
---

<Tag
  class={cn(
    'flex items-center gap-3 font-sans text-eyebrow font-semibold uppercase text-accent-text',
    className,
  )}
>
  {
    numero && (
      <>
        <span class="tabular-nums">{numero}</span>
        <span class="h-px w-7 bg-current opacity-50" aria-hidden="true" />
      </>
    )
  }
  <span><slot /></span>
</Tag>
