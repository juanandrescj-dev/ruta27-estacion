---
/**
 * Diferenciadores.astro — "por qué elegirnos" (#beneficios). Consume diferenciadores.yaml.
 * Cuatro razones concretas (galón exacto, 24/7, calidad, ubicación), cada una con su icono
 * Lucide. Tarjetas con tile de icono tintado en ámbar; superficie hundida para alternar el
 * ritmo de fondo respecto a las secciones vecinas.
 */
import { getCollection } from 'astro:content';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { Gauge, Clock, ShieldCheck, Navigation } from '@lucide/astro';

const diferenciadores = (await getCollection('diferenciadores')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const ICON: Record<string, unknown> = {
  galon: Gauge,
  horario: Clock,
  calidad: ShieldCheck,
  ubicacion: Navigation,
};
---

<Section
  id="beneficios"
  space="md"
  surface="sunken"
  containerSize="wide"
  labelledby="beneficios-title"
>
  <div class="max-w-2xl" data-reveal>
    <Eyebrow numero="04">Por qué Ruta 27</Eyebrow>
    <h2 id="beneficios-title" class="mt-3 font-display text-h1 font-semibold text-balance">
      Razones para entrar y no seguir de largo.
    </h2>
  </div>

  <ul class="mt-12 grid gap-4 sm:grid-cols-2" data-reveal-group>
    {
      diferenciadores.map((d) => {
        const Icono = ICON[d.data.icono] as typeof Gauge;
        return (
          <li class="flex h-full flex-col rounded-lg border border-line bg-surface p-7 shadow-1">
            <span
              class="inline-flex size-12 items-center justify-center rounded-md text-accent-text [&_svg]:[stroke-width:1.75]"
              style="background-color: color-mix(in oklab, var(--accent) 16%, transparent)"
            >
              <Icono size={24} />
            </span>
            <h3 class="mt-5 font-display text-h3 font-semibold text-ink">{d.data.titulo}</h3>
            <p class="mt-2 text-body text-ink-muted">{d.data.descripcion}</p>
          </li>
        );
      })
    }
  </ul>
</Section>
