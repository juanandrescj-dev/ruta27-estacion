---
/**
 * Diferenciadores.astro — "por qué elegirnos" (#beneficios). Consume diferenciadores.yaml.
 * Cuatro razones concretas (galón exacto, 24/7, calidad, ubicación), cada una con su icono
 * Lucide. Tarjetas con tile de icono tintado en ámbar; superficie hundida para alternar el
 * ritmo de fondo respecto a las secciones vecinas.
 */
import { getCollection } from 'astro:content';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import { Gauge, Clock, ShieldCheck, Navigation } from '@lucide/astro';

const diferenciadores = (await getCollection('diferenciadores')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const ICON: Record<string, unknown> = {
  galon: Gauge,
  horario: Clock,
  calidad: ShieldCheck,
  ubicacion: Navigation,
};
---

<Section
  id="beneficios"
  space="md"
  surface="sunken"
  containerSize="wide"
  labelledby="beneficios-title"
>
  <div class="max-w-2xl" data-reveal>
    <Eyebrow numero="04">Por qué Ruta 27</Eyebrow>
    <h2 id="beneficios-title" class="mt-3 font-display text-h1 font-semibold text-balance">
      Razones para entrar y no seguir de largo.
    </h2>
  </div>

  {
    /* Bento asimétrico (anti-IA tell #5): la razón principal (galón exacto) domina como tile
      alto a la izquierda; la última ocupa el ancho doble. No es un grid de cards clónicas. */
  }
  <ul class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
    {
      diferenciadores.map((d, i) => {
        const Icono = ICON[d.data.icono] as typeof Gauge;
        const destacado = i === 0;
        const ancho = i === diferenciadores.length - 1;
        return (
          <li
            class:list={[
              'flex h-full flex-col rounded-lg border border-line bg-surface',
              destacado
                ? 'p-8 shadow-2 sm:col-span-2 lg:col-span-1 lg:row-span-2 lg:p-9'
                : 'p-7 shadow-1',
              ancho && 'lg:col-span-2',
            ]}
          >
            <span
              class:list={[
                'inline-flex items-center justify-center rounded-md text-accent-text [&_svg]:[stroke-width:1.75]',
                destacado ? 'size-14' : 'size-12',
              ]}
              style="background-color: color-mix(in oklab, var(--accent) 16%, transparent)"
            >
              <Icono size={destacado ? 28 : 24} />
            </span>
            <h3
              class:list={[
                'mt-5 font-display font-semibold text-ink',
                destacado ? 'text-h2' : 'text-h3',
              ]}
            >
              {d.data.titulo}
            </h3>
            <p class:list={['mt-2 text-ink-muted', destacado ? 'max-w-md text-lead' : 'text-body']}>
              {d.data.descripcion}
            </p>
            {destacado && (
              <span
                class="mt-auto pt-8 font-display text-h3 font-semibold text-accent-text tabular-nums"
                aria-hidden="true"
              >
                01
              </span>
            )}
          </li>
        );
      })
    }
  </ul>
</Section>
