---
/**
 * Ubicacion.astro — ubicación de la estación (#ubicacion). Asimétrico 5/7:
 * panel informativo con detalles y botones directos a Google Maps/Waze a la izquierda,
 * y el mapa interactivo (isla React lazy-loaded) a la derecha.
 * Datos leídos de estacion.yaml.
 */
import { getEntry } from 'astro:content';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import MapaInteractivo from '../interactive/MapaInteractivo';
import { MapPin, Navigation } from '@lucide/astro';

const estacionEntry = await getEntry('estacion', 'ruta27');
const estacion = estacionEntry?.data;

if (!estacion) {
  throw new Error('No se encontraron datos de la estación en la colección.');
}

const { geo, direccion, nombre } = estacion;
const googleMapsUrl = `https://maps.google.com/?q=${geo.lat},${geo.lng}`;
const wazeUrl = `https://waze.com/ul?ll=${geo.lat},${geo.lng}&navigate=yes`;
---

<Section id="ubicacion" space="lg" containerSize="wide" labelledby="ubicacion-title">
  <div class="grid items-center gap-10 lg:grid-cols-12 lg:gap-14">
    <!-- Información: 5/12 -->
    <div class="flex flex-col justify-center lg:col-span-5" data-reveal-group>
      <Eyebrow numero="06">Ubicación</Eyebrow>
      <h2 id="ubicacion-title" class="mt-3 font-display text-h1 font-semibold text-balance">
        Fácil de encontrar, directo en tu ruta.
      </h2>
      <p class="mt-5 text-lead text-ink-muted">
        Estamos estratégicamente ubicados en el corazón de la Autopista Duarte, listos para servirte
        en tu trayecto por la región norte.
      </p>

      <div
        class="mt-7 flex items-start gap-3 rounded-lg border border-line bg-surface p-5 shadow-1"
      >
        <MapPin class="mt-1 size-5 shrink-0 text-accent-text" aria-hidden="true" />
        <div>
          <h3 class="font-display text-body font-semibold text-ink">Dirección física</h3>
          <p class="mt-1 text-small leading-relaxed text-ink-muted">{direccion}</p>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-4">
        <Button variant="primario" href={googleMapsUrl} target="_blank" rel="noopener noreferrer">
          <Navigation size={18} class="mr-1" aria-hidden="true" /> Abrir en Google Maps
        </Button>
        <Button variant="secundario" href={wazeUrl} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" class="mr-1 size-[18px]" aria-hidden="true">
            <path
              d="M19.14 10.43a7.71 7.71 0 0 0-15 .86A6.29 6.29 0 0 0 6.29 17.5a1.71 1.71 0 0 1 1.71 1.71v.57a3.43 3.43 0 0 0 6.86 0v-.57a1.71 1.71 0 0 1 1.71-1.71 6.29 6.29 0 0 0 2.57-7.07Zm-9.43 2.57a1.29 1.29 0 1 1 1.29-1.29 1.29 1.29 0 0 1-1.29 1.29Zm4.29 0a1.29 1.29 0 1 1 1.29-1.29 1.29 1.29 0 0 1-1.29 1.29Z"
            ></path>
          </svg>
          Abrir en Waze
        </Button>
      </div>
    </div>

    <!-- Mapa interactivo: 7/12 -->
    <div class="lg:col-span-7" data-reveal>
      <MapaInteractivo
        client:visible
        lat={geo.lat}
        lng={geo.lng}
        nombre={nombre}
        direccion={direccion}
      />
    </div>
  </div>
</Section>
