---
/**
 * Horarios.astro — horario semanal (#horarios). Asimétrico 5/7: panel de estado "Abierto
 * ahora" + tabla de la semana. El estado se calcula con horarios.ts en el build; como la
 * estación es 24/7, el valor es siempre correcto sin necesidad de JS. Un script mínimo (sin
 * isla) marca la fila de "Hoy" según el día del visitante (preciso por cliente).
 * Los datos coinciden con el openingHoursSpecification del JSON-LD (lib/seo.ts).
 */
import { getCollection } from 'astro:content';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import {
  estaAbiertoAhora,
  formatHora12,
  ordenarSemana,
  type DiaHorario,
} from '../../lib/utils/horarios';
import { Clock, MessageCircle } from '@lucide/astro';
import { getEntry } from 'astro:content';

const horarios: DiaHorario[] = ordenarSemana(
  (await getCollection('horarios')).map((e) => ({ id: e.id, ...e.data })),
);
const estado = estaAbiertoAhora(horarios);

const estacion = (await getEntry('estacion', 'ruta27'))?.data;
const waHref = estacion
  ? `https://wa.me/${estacion.whatsapp}?text=${encodeURIComponent('Hola, quisiera información sobre Ruta 27.')}`
  : '#';

const horarioTexto = (d: DiaHorario): string =>
  d.abierto24h || !d.apertura || !d.cierre
    ? '24 horas'
    : `${formatHora12(d.apertura)} – ${formatHora12(d.cierre)}`;
---

<Section id="horarios" space="lg" containerSize="wide" labelledby="horarios-title">
  <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
    <!-- Panel de estado: 5/12 -->
    <div class="lg:col-span-5" data-reveal-group>
      <Eyebrow numero="06">Horarios</Eyebrow>
      <h2 id="horarios-title" class="mt-3 font-display text-h1 font-semibold text-balance">
        Siempre abierto, sin excepciones.
      </h2>

      <div class="mt-7 rounded-lg border border-line bg-surface p-7 shadow-1">
        <p class="flex items-center gap-2.5">
          <span
            class:list={[
              'inline-flex size-2.5 shrink-0 rounded-full',
              estado.abierto ? 'bg-brand' : 'bg-signal',
            ]}
            aria-hidden="true"
          >
          </span>
          <span class="font-display text-h3 font-semibold text-ink">{estado.etiqueta}</span>
        </p>
        <p class="mt-3 flex items-start gap-2.5 text-body text-ink-muted">
          <Clock size={18} class="mt-0.5 shrink-0" aria-hidden="true" />
          {estado.detalle}
        </p>
        <div class="mt-6">
          <Button variant="secundario" href={waHref} target="_blank" rel="noopener noreferrer">
            <MessageCircle size={18} aria-hidden="true" /> Escríbenos por WhatsApp
          </Button>
        </div>
      </div>
    </div>

    <!-- Tabla semanal: 7/12 -->
    <div class="lg:col-span-7" data-reveal>
      <div class="overflow-hidden rounded-lg border border-line">
        <table class="w-full border-collapse text-left">
          <caption class="sr-only">Horario de atención por día de la semana</caption>
          <thead class="bg-surface-sunken">
            <tr class="text-eyebrow tracking-[0.12em] text-ink-muted uppercase">
              <th scope="col" class="px-5 py-3.5 font-semibold">Día</th>
              <th scope="col" class="px-5 py-3.5 font-semibold">Horario</th>
            </tr>
          </thead>
          <tbody>
            {
              horarios.map((d) => (
                <tr data-dia={d.id} class="fila-dia border-t border-line bg-surface">
                  <th scope="row" class="px-5 py-4 font-display font-semibold text-ink">
                    <span class="inline-flex items-center gap-2.5">
                      {d.dia}
                      <span
                        data-hoy-label
                        hidden
                        class="rounded-full border border-[color-mix(in_oklab,var(--accent)_32%,transparent)] bg-[color-mix(in_oklab,var(--accent)_16%,transparent)] px-2 py-0.5 text-eyebrow font-semibold tracking-[0.1em] text-accent-text uppercase"
                      >
                        Hoy
                      </span>
                    </span>
                  </th>
                  <td class="px-5 py-4 text-body text-ink-muted tabular-nums">{horarioTexto(d)}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-small text-ink-muted">
        Horario vigente todo el año, incluidos días feriados.
      </p>
    </div>
  </div>
</Section>

<style>
  /* Estado "Hoy": lo activa el script de abajo añadiendo [data-hoy] a la fila del día actual.
     CSS plano (no la variante data-* de Tailwind) para no depender de su soporte de atributos
     booleanos; todo el color sale de tokens. */
  .fila-dia[data-hoy] {
    background-color: color-mix(in oklab, var(--accent) 10%, transparent);
  }
  .fila-dia[data-hoy] th[scope='row'] {
    color: var(--brand);
  }
</style>

{
  /* Realce de "Hoy" según el día del visitante (no del build). Se reengancha en cada
    `astro:page-load` para sobrevivir a las View Transitions del ClientRouter. */
}
<script>
  function marcarHoy() {
    const ids = ['dom', 'lun', 'mar', 'mie', 'jue', 'vie', 'sab'];
    const hoy = ids[new Date().getDay()];
    const fila = document.querySelector<HTMLElement>('[data-dia="' + hoy + '"]');
    if (!fila) return;
    fila.setAttribute('data-hoy', '');
    const etiqueta = fila.querySelector<HTMLElement>('[data-hoy-label]');
    if (etiqueta) etiqueta.hidden = false;
  }

  document.addEventListener('astro:page-load', marcarHoy);
</script>
