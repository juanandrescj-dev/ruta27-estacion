---
/**
 * SobreLaEstacion.astro — historia de la estación (#nosotros). Asimétrico 5/7 ESPEJADO
 * respecto al hero (imagen a la izquierda) para variar el ritmo. Historia concreta y
 * dominicana que humaniza (anti-tell), datos factuales (nada de cifras ni reseñas inventadas).
 * El hueco de imagen reserva su caja para la foto real de la Fase 5.
 */
import { getCollection } from 'astro:content';
import { Picture } from 'astro:assets';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import equipoImg from '../../assets/images/estacion/equipo-atendiendo.jpg';

const numServicios = (await getCollection('servicios')).length;

const datos = [
  { valor: '24/7', etiqueta: 'Abierta todos los días del año' },
  { valor: 'Km 8', etiqueta: 'Autopista Duarte, Santiago' },
  { valor: `${numServicios}`, etiqueta: 'Servicios en una sola parada' },
];
---

<Section id="nosotros" space="xl" containerSize="wide" labelledby="nosotros-title">
  <div class="grid items-center gap-10 lg:grid-cols-12 lg:gap-14">
    <!-- Imagen: 5/12 (izquierda) -->
    <div class="lg:col-span-5" data-reveal>
      <figure
        class="relative aspect-[5/4] overflow-hidden rounded-xl border border-line bg-surface-sunken shadow-2"
      >
        <Picture
          src={equipoImg}
          formats={['avif', 'webp']}
          widths={[400, 600, 800, 1000, 1280]}
          sizes="(min-width: 1024px) 40vw, (min-width: 640px) 88vw, 100vw"
          alt="Empleado de Ruta 27 en uniforme verde y ámbar atendiendo el surtidor con la terminal de pago en mano."
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-bl from-[color-mix(in_oklab,var(--brand)_28%,transparent)] via-transparent to-transparent"
          aria-hidden="true"
        >
        </div>
        <span
          class="pointer-events-none absolute top-5 left-5 font-display text-h1 leading-none font-semibold text-paper/60 tabular-nums select-none"
          aria-hidden="true"
        >
          03
        </span>
        <figcaption
          class="absolute inset-x-0 bottom-0 border-t border-line bg-surface px-5 py-3 text-small text-ink-muted"
        >
          Patio de servicio · Ruta 27
        </figcaption>
      </figure>
    </div>

    <!-- Texto: 7/12 (derecha) -->
    <div class="lg:col-span-7" data-reveal-group>
      <Eyebrow numero="03">Sobre la estación</Eyebrow>
      <h2 id="nosotros-title" class="mt-3 font-display text-h1 font-semibold text-balance">
        Gente de la zona, atendiendo la ruta de Santiago.
      </h2>
      <div class="mt-5 flex max-w-2xl flex-col gap-4 text-lead text-ink-muted">
        <p>
          Ruta 27 nació a pie de la Autopista Duarte, en el Km 8 de Santiago, con una idea sencilla:
          que parar a tanquear no sea un trámite. Surtidores calibrados, personal de la zona y las
          luces siempre encendidas — de día, de madrugada y en feriado.
        </p>
        <p>
          Aquí el galón es exacto y el trato es de vecino. Cuidamos el combustible, la tienda y cada
          detalle para que sigas tu camino tranquilo.
        </p>
      </div>

      <dl class="mt-9 grid grid-cols-3 gap-6 border-t border-line pt-7">
        {
          datos.map((d) => (
            <div>
              <dt class="font-display text-h2 font-semibold text-brand tabular-nums">{d.valor}</dt>
              <dd class="mt-1 text-small text-ink-muted">{d.etiqueta}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</Section>
