---
/**
 * FAQ.astro — preguntas frecuentes (#faq). Asimétrico 4/8: título a la izquierda, acordeón a
 * la derecha. Usa <details>/<summary> NATIVO (accesible por teclado sin JS, §9.4). El chevron
 * rota con CSS plano según el estado [open]. Las mismas preguntas alimentan el FAQPage JSON-LD
 * (lib/seo.ts) desde index.astro, así dato visible y estructurado nunca se desincronizan.
 */
import { getCollection, getEntry } from 'astro:content';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import { ChevronDown, MessageCircle } from '@lucide/astro';

const faq = (await getCollection('faq')).sort((a, b) => a.data.orden - b.data.orden);
const estacion = (await getEntry('estacion', 'ruta27'))?.data;
const waHref = estacion
  ? `https://wa.me/${estacion.whatsapp}?text=${encodeURIComponent('Hola, tengo una pregunta sobre Ruta 27.')}`
  : '#';
---

<Section id="faq" space="md" containerSize="wide" labelledby="faq-title">
  <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
    <!-- Encabezado: 4/12 -->
    <div class="lg:col-span-4" data-reveal-group>
      <Eyebrow numero="08">Preguntas frecuentes</Eyebrow>
      <h2 id="faq-title" class="mt-3 font-display text-h1 font-semibold text-balance">
        Lo que más nos preguntan.
      </h2>
      <p class="mt-4 text-body text-ink-muted">
        ¿No ves tu duda aquí? Escríbenos y te respondemos en seguida.
      </p>
      <div class="mt-6">
        <Button variant="ghost" href={waHref} target="_blank" rel="noopener noreferrer">
          <MessageCircle size={18} aria-hidden="true" /> Pregúntanos por WhatsApp
        </Button>
      </div>
    </div>

    <!-- Acordeón: 8/12 -->
    <div class="lg:col-span-8">
      <div class="border-t border-line" data-reveal-group>
        {
          faq.map((f) => (
            <details class="faq-item border-b border-line">
              <summary class="flex cursor-pointer items-center justify-between gap-5 py-5 [&::-webkit-details-marker]:hidden">
                <span class="font-display text-h3 font-semibold text-ink">{f.data.pregunta}</span>
                <ChevronDown
                  size={22}
                  class="faq-chevron mt-1 shrink-0 text-ink-muted transition-transform duration-200"
                  aria-hidden="true"
                />
              </summary>
              <p class="max-w-2xl pb-6 text-body text-ink-muted">{f.data.respuesta}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</Section>

<style>
  /* El chevron apunta hacia arriba cuando la pregunta está abierta (CSS plano, sin JS). */
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }
  /* En reduce-motion no animamos la rotación (global ya neutraliza transition-duration). */
</style>
