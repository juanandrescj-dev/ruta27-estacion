# Copia este archivo a `.env` y rellena los valores. `.env` está en .gitignore (no se versiona).
# Estos valores son para herramientas de DESARROLLO; el sitio estático no los necesita en build.

# API key del MCP de Context7 — docs actualizadas de Astro/Tailwind v4/Lenis (anti-alucinación de APIs).
# Consíguela gratis en https://context7.com
CONTEXT7_API_KEY=

# Access key pública de Web3Forms para el formulario de contacto (ej: 00000000-0000-0000-0000-000000000000)
# Regístrate en https://web3forms.com para obtener una clave gratis
PUBLIC_WEB3FORMS_ACCESS_KEY=
